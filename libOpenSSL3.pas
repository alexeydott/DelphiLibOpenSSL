// vsnprintf: C99-compliant wrapper over _vsnprintf
function vsnprintf(buf: PAnsiChar; size: NativeUInt; fmt: PAnsiChar; ap: Pointer): Integer; cdecl;
begin
  if (buf <> nil) and (size > 0) then begin
    Result := _vsnprintf(buf, size, fmt, ap);
    buf[size - 1] := #0;
  end else
    Result := 0;
end;
