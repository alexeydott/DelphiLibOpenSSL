// Using Delphi's heap avoids heap mismatch between msvcrt.dll and static CRT.
function malloc(size: NativeUInt): Pointer; cdecl;
begin Result := System.GetMemory(size); end;

function calloc(num, size: NativeUInt): Pointer; cdecl;
begin Result := System.AllocMem(num * size); end;

function realloc(p: Pointer; size: NativeUInt): Pointer; cdecl;
begin Result := System.ReallocMemory(p, size); end;

procedure free(p: Pointer); cdecl;
begin if p <> nil then System.FreeMemory(p); end;

function _strdup(s: PAnsiChar): PAnsiChar; cdecl;
var len: NativeUInt;
begin
  if s = nil then begin Result := nil; Exit; end;
  len := StrLenA(s) + 1;
  Result := System.GetMemory(len);
  if Result <> nil then Move(s^, Result^, len);
end;

