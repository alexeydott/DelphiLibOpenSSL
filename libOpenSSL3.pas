// --- Stack probe without allocation ---
// Clang emits calls to __chkstk_noalloc for large stack frames.
// Probes each 4KB page without adjusting ESP.
procedure __chkstk_noalloc;
asm
  push ecx
  lea ecx, [esp+8]
@loop:
  sub ecx, $1000
  test [ecx], ecx
  sub eax, $1000
  ja @loop
  pop ecx
end;

