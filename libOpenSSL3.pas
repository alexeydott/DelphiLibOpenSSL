function _wcscpy(dest, src: PWideChar): PWideChar; cdecl;
var
  d, s: PWideChar;
begin
  d := dest;
  s := src;
  while s^ <> #0 do begin
    d^ := s^;
    Inc(d);
    Inc(s);
  end;
  d^ := #0;
  Result := dest;
end;

