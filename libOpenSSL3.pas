unit libOpenSSL3;

// OpenSSL 3.x/4.x static bindings for Delphi
// Ported from OpenSSL 4.1.0 C headers (c_src\openssl\include\openssl\)

{$IFDEF MSWINDOWS}
{.$WEAKPACKAGEUNIT}
{$WARN SYMBOL_PLATFORM OFF}

{$ENDIF}
{$A+}
{$Z+}

// CPU detection
{$IFDEF CPUX64}
  {$DEFINE CPU64}
{$ELSE}
  {$DEFINE CPUX86}
  {$DEFINE CPU32}
{$ENDIF}

// OpenSSL 3.x deprecation compatibility defines
{$DEFINE DEPRECATEDIN_0_9_8}
{$DEFINE DEPRECATEDIN_1_1_0}
{$DEFINE DEPRECATEDIN_3_0}

// === OpenSSL version selection ===
// Uncomment ONE of the following:
// {$DEFINE OPENSSL_3X}   // < uncomment for OpenSSL 3.x
{$DEFINE OPENSSL_4X}      // < default: OpenSSL 4.x

{$IFDEF OPENSSL_3X}{$IFDEF OPENSSL_4X}
  'Error: Define exactly one of OPENSSL_3X or OPENSSL_4X'
{$ENDIF}{$ENDIF}
{$IFNDEF OPENSSL_3X}{$IFNDEF OPENSSL_4X}
  'Error: Define exactly one of OPENSSL_3X or OPENSSL_4X'
{$ENDIF}{$ENDIF}

{$DEFINE STATIC_LEGACY}

{$DEFINE OPENSSL_NO_CRYPTO_MDEBUG}
{$DEFINE OPENSSL_NO_EC_NISTP_64_GCC_128}
{$DEFINE OPENSSL_NO_EGD}
{$DEFINE OPENSSL_NO_MD2}
{$DEFINE OPENSSL_NO_RC5}
{$DEFINE OPENSSL_NO_SCTP}
{$DEFINE OPENSSL_NO_SSL_TRACE}
{$DEFINE OPENSSL_NO_SSL3_METHOD}
{$DEFINE OPENSSL_NO_UNIT_TEST}

// OpenSSL 3.x provider architecture - engine subsystem removed
{$DEFINE OPENSSL_NO_ENGINE}

// Int64 always available on Win32/Win64 Delphi
{$DEFINE SUPPORTS_INT64}

// Suppress false-positive comparison warnings from generated code
{$WARN COMPARISON_FALSE OFF}
{$WARN COMPARISON_TRUE OFF}

interface

uses
  System.SysUtils, System.Math, Winapi.Windows, Winapi.WinSock2;

// C compiler detection selects which obj directory to link.
//   Win32 default: bcc32 (obj3\win32\bcc or obj4\win32\bcc)
//                  change to C_COMPILER_MSC_32 for VC
//                  or C_COMPILER_BCC32C for bcc32c (Clang)
//   Win64 default: MSVC  (obj3\win64\vc or obj4\win64\vc)
//                  change to C_COMPILER_BORLAND_64 for bcc64
//
// To switch compiler, comment/uncomment the {$DEFINE} below.
//
// NOTE: bcc32c (Clang-based) uses cdecl calling convention with underscore
//   prefix (_functionName). Objects are linked from obj3\win32\bcc32c or obj4\win32\bcc32c.
//   Full bcc32c support requires cdecl external declarations - see TODO below.
{$UNDEF C_COMPILER_BORLAND}
{$UNDEF C_COMPILER_BORLAND_32}
{$UNDEF C_COMPILER_BORLAND_64}
{$UNDEF C_COMPILER_BCC32C}
{$UNDEF C_COMPILER_MSC}
{$UNDEF C_COMPILER_MSC_32}
{$UNDEF C_COMPILER_MSC_64}
{$UNDEF __CDECL}
{$IFDEF CPUX86}
   {$DEFINE C_COMPILER_BORLAND_32}  // < Win32 default: bcc32 (register convention)
   {.$DEFINE C_COMPILER_BCC32C}     // < uncomment for bcc32c (cdecl + underscore)
   {.$DEFINE C_COMPILER_MSC_32}     // < uncomment for MSVC Win32 (cdecl + underscore)
{$ELSE}
{$IFDEF CPUX64}
   {$DEFINE C_COMPILER_MSC_64}      // < Win64 default: MSVC
   {.$DEFINE C_COMPILER_BORLAND_64} // < uncomment for bcc64 Win64
{$ELSE}
  'Error: C compiler for this CPU not yet $DEFINEd.'
{$ENDIF}
{$ENDIF}
// Umbrella defines: C_COMPILER_BORLAND = any Borland, C_COMPILER_MSC = any MSVC
{$IFDEF C_COMPILER_BORLAND_32}{$DEFINE C_COMPILER_BORLAND}{$ENDIF}
{$IFDEF C_COMPILER_BCC32C}   {$DEFINE C_COMPILER_BORLAND}{$ENDIF}
{$IFDEF C_COMPILER_BORLAND_64}{$DEFINE C_COMPILER_BORLAND}{$ENDIF}
{$IFDEF C_COMPILER_MSC_32}   {$DEFINE C_COMPILER_MSC}    {$ENDIF}
{$IFDEF C_COMPILER_MSC_64}   {$DEFINE C_COMPILER_MSC}    {$ENDIF}

{$IFDEF C_COMPILER_BCC32C}{$DEFINE __CDECL}{$ENDIF}
{$IFDEF C_COMPILER_MSC_32}{$DEFINE __CDECL}{$ENDIF}

const
  EXTERNAL_NAME_PREFIX = {$IFDEF WIN32}{$IFNDEF C_COMPILER_BORLAND_32}'_'{$ELSE}''{$ENDIF}{$ELSE}''{$ENDIF};
  // OpenSSL version constants
{$IFDEF OPENSSL_4X}
  OPENSSL_VERSION_MAJOR_ = 4;
  OPENSSL_VERSION_MINOR_= 1;
  OPENSSL_VERSION_PATCH_ = 0;

  OPENSSL_VERSION_NUMBER = $41000000;
  OPENSSL_VERSION_TEXT = 'OpenSSL 4.1.0';
//  OPENSSL_VERSION_PRE_RELEASE = '-dev';
  OPENSSL_SHLIB_VERSION = 4;
{$ENDIF}
{$IFDEF OPENSSL_3X}
  OPENSSL_VERSION_MAJOR_ = 3;
  OPENSSL_VERSION_MINOR_= 6;
  OPENSSL_VERSION_PATCH_ = 1;

  OPENSSL_VERSION_NUMBER = $30601000;
  OPENSSL_VERSION_TEXT = 'OpenSSL 3.6.1';
  OPENSSL_SHLIB_VERSION = 3;
{$ENDIF}

  // OpenSSL 3.x version info type constants
  OPENSSL_VERSION_const     = 0;
  OPENSSL_CFLAGS            = 1;
  OPENSSL_BUILT_ON          = 2;
  OPENSSL_PLATFORM          = 3;
  OPENSSL_DIR               = 4;
  OPENSSL_ENGINES_DIR       = 5;
  OPENSSL_MODULES_DIR       = 6;
  OPENSSL_CPU_INFO          = 7;

  // OPENSSL_info() type constants (new in 3.x)
  OPENSSL_INFO_CONFIG_DIR        = 1001;
  OPENSSL_INFO_ENGINES_DIR       = 1002;
  OPENSSL_INFO_MODULES_DIR       = 1003;
  OPENSSL_INFO_DSO_EXTENSION     = 1004;
  OPENSSL_INFO_DIR_FILENAME_SEPARATOR = 1005;
  OPENSSL_INFO_LIST_SEPARATOR    = 1006;
