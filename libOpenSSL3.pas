// _ltolower: Borland locale-aware lowercase (ASCII stub)
function _ltolower(c: Integer): Integer; cdecl;
begin
  if (c >= Ord('A')) and (c <= Ord('Z')) then
    Result := c + 32
  else
    Result := c;
end;

// _malloca / _freea: Clang alloca helpers (use Delphi heap)
function _malloca(size: NativeUInt): Pointer; cdecl;
begin
  Result := System.GetMemory(size);
end;

procedure _freea(p: Pointer); cdecl;
begin
  if p <> nil then System.FreeMemory(p);
end;

// _InlineInterlockedAdd64: Clang intrinsic (atomic add, returns new value)
function _InlineInterlockedAdd64(Addend: Pointer; Value: Int64): Int64;
asm
  .noframe
  mov rax, rdx
  lock xadd [rcx], rax
  add rax, rdx
end;

// MemoryBarrier: CPU memory fence (x86-64)
procedure MemoryBarrier;
asm
  .noframe
  mfence
end;

