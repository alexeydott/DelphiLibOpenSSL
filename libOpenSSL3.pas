type
  TQSortCompare = function(a, b: Pointer): Integer; {$IFDEF __CDECL}cdecl;{$ENDIF} // register for BCC32 -pr, cdecl for BCC32C/MSVC_32

procedure _qsort(base: Pointer; num, size: Cardinal; compare: TQSortCompare); cdecl;
var
  i, j: Cardinal;
  p, q: PByte;
  tmp: array[0..1023] of Byte;
begin
  Inc(_stub_qsort_count);
  if (base = nil) or (num <= 1) or (size = 0) or (size > 1024) then
    Exit;
  for i := 0 to num - 2 do
    for j := 0 to num - 2 - i do
    begin
      p := PByte(NativeUInt(base) + NativeUInt(j) * NativeUInt(size));
      q := PByte(NativeUInt(base) + NativeUInt(j + 1) * NativeUInt(size));
      if compare(p, q) > 0 then
      begin
        Move(p^, tmp[0], size);
        Move(q^, p^, size);
        Move(tmp[0], q^, size);
      end;
    end;
end;


