var
  _daylight: Integer = 1;
  _timezone: Integer = 0;

procedure _tzset;
var
  tzi: TTimeZoneInformation;
begin
  GetTimeZoneInformation(tzi);
  if (tzi.DaylightDate.wMonth = 0) or (tzi.DaylightBias = 0) then
    _daylight := 0
  else
    _daylight := 1;
  _timezone := (tzi.Bias + tzi.StandardBias) * 60;
end;


type
  atexit_rec_ptr = ^atexit_rec;
  atexit_rec = record
    Proc: atexit_proc;
    Next: atexit_rec_ptr;
  end;

var
  atexit_list: atexit_rec_ptr = nil;

function atexit(Proc: atexit_proc): Integer;
var
  p: atexit_rec_ptr;
begin
  GetMem(p, SizeOf(p^));
  p^.Proc := Proc;
  p^.Next := atexit_list;
  atexit_list := p;
  Result := 0;
end;

procedure atexit_execute;
var
  p, pNext: atexit_rec_ptr;
begin
  p := atexit_list;
  while Assigned(p) do
  begin
    p^.Proc;
    pNext := p^.Next;
    FreeMem(p);
    p := pNext;
  end;
end;


procedure OPENSSL_PrintLN(const AText: string);
begin
  if IsConsole then
    Writeln(AText)
  else
    OutputDebugString(PChar(AText));
end;

procedure OPENSSL_PrintLN(const AFmt: string; Args: array of const);
begin
  OPENSSL_PrintLN(Format(AFmt, Args));
end;

