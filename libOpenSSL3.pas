// Inline BIO helpers
function BIO_flush(b: BIO_ptr): Integer;
begin
  Result := BIO_ctrl(b, BIO_CTRL_FLUSH, 0, nil);
end;

function BIO_pending(b: BIO_ptr): Integer;
begin
  Result := BIO_ctrl(b, BIO_CTRL_PENDING_, 0, nil);
end;

function BIO_wpending(b: BIO_ptr): Integer;
begin
  Result := BIO_ctrl(b, BIO_CTRL_WPENDING_, 0, nil);
end;

function BIO_get_mem_data(b: BIO_ptr; pp: Pointer): Integer;
begin
  Result := BIO_ctrl(b, BIO_CTRL_INFO, 0, pp);
end;

function BIO_get_flags(const b: BIO_ptr): Integer;
begin
  Result := BIO_test_flags(b, not Integer(0));
end;

function BIO_should_read(b: BIO_ptr): Boolean;
begin
  Result := (BIO_test_flags(b, BIO_FLAGS_READ) <> 0);
end;

function BIO_should_write(b: BIO_ptr): Boolean;
begin
  Result := (BIO_test_flags(b, BIO_FLAGS_WRITE) <> 0);
end;

function BIO_should_retry(b: BIO_ptr): Boolean;
begin
  Result := (BIO_test_flags(b, BIO_FLAGS_SHOULD_RETRY) <> 0);
end;

function BIO_should_io_special(b: BIO_ptr): Boolean;
begin
  Result := (BIO_test_flags(b, BIO_FLAGS_IO_SPECIAL) <> 0);
end;

function BIO_set_close(b: BIO_ptr; c: Integer): Integer;
begin
  Result := BIO_ctrl(b, BIO_CTRL_SET_CLOSE, c, nil);
end;

function BIO_get_close(b: BIO_ptr): Integer;
begin
  Result := BIO_ctrl(b, BIO_CTRL_GET_CLOSE, 0, nil);
end;

function BIO_seek(b: BIO_ptr; ofs: Integer): Integer;
begin
  Result := BIO_ctrl(b, BIO_C_FILE_SEEK, ofs, nil);
end;

function BIO_tell(b: BIO_ptr): Integer;
begin
  Result := BIO_ctrl(b, BIO_C_FILE_TELL, 0, nil);
end;

function BIO_reset(b: BIO_ptr): Integer;
begin
  Result := BIO_ctrl(b, BIO_CTRL_RESET, 0, nil);
end;

