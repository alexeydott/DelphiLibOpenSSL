// Debug counters for stub function calls
var
  _stub_malloc_count: Integer = 0;
  _stub_realloc_count: Integer = 0;
  _stub_free_count: Integer = 0;
  _stub_qsort_count: Integer = 0;
  _stub_vsnprintf_count: Integer = 0;
  _stub_strcmp_count: Integer = 0;
  _stub_getenv_count: Integer = 0;
  _stub_errno_count: Integer = 0;

procedure ResetStubCounters;
begin
  _stub_malloc_count := 0;
  _stub_realloc_count := 0;
  _stub_free_count := 0;
  _stub_qsort_count := 0;
  _stub_vsnprintf_count := 0;
  _stub_strcmp_count := 0;
  _stub_getenv_count := 0;
  _stub_errno_count := 0;
end;

procedure DumpStubCounters;
begin
  Writeln('  malloc: ', _stub_malloc_count);
  Writeln('  realloc: ', _stub_realloc_count);
  Writeln('  free: ', _stub_free_count);
  Writeln('  qsort: ', _stub_qsort_count);
  Writeln('  vsnprintf: ', _stub_vsnprintf_count);
  Writeln('  strcmp: ', _stub_strcmp_count);
  Writeln('  getenv: ', _stub_getenv_count);
  Writeln('  errno: ', _stub_errno_count);
end;

procedure GetStubCounts(out MallocCount, FreeCount, ReallocCount: Integer);
begin
  MallocCount := _stub_malloc_count;
  FreeCount := _stub_free_count;
  ReallocCount := _stub_realloc_count;
end;

// --- Standard C library functions (bcc32 cdecl with _ prefix) ---

function _memset(dest: Pointer; c: Integer; n: Cardinal): Pointer; cdecl;
begin
  FillChar(dest^, n, Byte(c));
  Result := dest;
end;

function _memcpy(dest: Pointer; src: Pointer; n: Cardinal): Pointer; cdecl;
begin
  Move(src^, dest^, n);
  Result := dest;
end;

function _memmove(dest: Pointer; src: Pointer; n: Cardinal): Pointer; cdecl;
begin
  Move(src^, dest^, n);
  Result := dest;
end;

function _memchr(s: Pointer; c: Integer; n: Cardinal): Pointer; cdecl;
var
  p: PByte;
  i: Cardinal;
begin
  p := s;
  for i := 0 to n - 1 do
  begin
    if p^ = Byte(c) then begin Result := p; Exit; end;
    Inc(p);
  end;
  Result := nil;
end;

function _memcmp(s1: Pointer; s2: Pointer; n: Cardinal): Integer; cdecl;
var
  p1, p2: PByte;
  i: Cardinal;
begin
  p1 := s1; p2 := s2;
  for i := 0 to n - 1 do
  begin
    if p1^ <> p2^ then begin
      if p1^ < p2^ then Result := -1 else Result := 1;
      Exit;
    end;
    Inc(p1); Inc(p2);
  end;
  Result := 0;
end;

function _strlen(s: PAnsiChar): Cardinal; cdecl;
begin
  Result := StrLenA(s);
end;

function _strncmp(s1, s2: PAnsiChar; n: Cardinal): Integer; cdecl;
var
  i: Cardinal;
begin
  for i := 0 to n - 1 do
  begin
    if s1[i] <> s2[i] then begin
      if Byte(s1[i]) < Byte(s2[i]) then Result := -1 else Result := 1;
      Exit;
    end;
    if s1[i] = #0 then begin Result := 0; Exit; end;
  end;
  Result := 0;
end;

function _strncpy(dest, src: PAnsiChar; n: Cardinal): PAnsiChar; cdecl;
var
  i, j: Cardinal;
begin
  Result := dest;
  for i := 0 to n - 1 do
  begin
    if src[i] = #0 then begin
      j := i; while j < n do begin dest[j] := #0; Inc(j); end;
      Exit;
    end;
    dest[i] := src[i];
  end;
end;

function _strchr(s: PAnsiChar; c: Integer): PAnsiChar; cdecl;
begin
  while s^ <> #0 do
  begin
    if Byte(s^) = Byte(c) then begin Result := s; Exit; end;
    Inc(s);
  end;
  if Byte(c) = 0 then Result := s else Result := nil;
end;

function _strrchr(s: PAnsiChar; c: Integer): PAnsiChar; cdecl;
var
  last: PAnsiChar;
begin
  last := nil;
  while s^ <> #0 do
  begin
    if Byte(s^) = Byte(c) then last := s;
    Inc(s);
  end;
  if Byte(c) = 0 then Result := s else Result := last;
end;

function _strtoul(s: PAnsiChar; endptr: PPAnsiChar; base: Integer): Cardinal; cdecl;
var
  n: Cardinal;
  c: Byte;
  digit: Integer;
begin
  n := 0;
  while (s^ = ' ') or (s^ = #9) do Inc(s);
  if base = 0 then begin
    if s^ = '0' then begin
      Inc(s);
      if (s^ = 'x') or (s^ = 'X') then begin base := 16; Inc(s); end
      else base := 8;
    end else base := 10;
  end;
  while s^ <> #0 do begin
    c := Byte(s^);
    if (c >= Byte('0')) and (c <= Byte('9')) then digit := c - Byte('0')
    else if (c >= Byte('a')) and (c <= Byte('f')) then digit := c - Byte('a') + 10
    else if (c >= Byte('A')) and (c <= Byte('F')) then digit := c - Byte('A') + 10
    else Break;
    if digit >= base then Break;
    n := n * Cardinal(base) + Cardinal(digit);
    Inc(s);
  end;
  if endptr <> nil then endptr^ := s;
  Result := n;
end;

function _strtol(s: PAnsiChar; endptr: PPAnsiChar; base: Integer): Integer; cdecl;
var
  neg: Boolean;
begin
  while (s^ = ' ') or (s^ = #9) do Inc(s);
  neg := s^ = '-';
  if neg or (s^ = '+') then Inc(s);
  Result := Integer(_strtoul(s, endptr, base));
  if neg then Result := -Result;
end;

// === File I/O - custom C_FILE implementation ===
// All stdio functions use Windows API directly via C_FILE.Handle.
// BCC32 OBJs call these with cdecl convention (_RTLENTRY = __cdecl in headers).

var
  errno: Integer = 0;  // global CRT errno (not thread-safe, but matches BCC32 static model)
  open_files: C_FILE_ptr = nil;

function new_open_file: C_FILE_ptr;
var
  n: Integer;
  p, pPrev: C_FILE_ptr;
begin
  n := 1;
  pPrev := nil;
  p := open_files;
  while Assigned(p) and (p^.FD = n) do
  begin
    Inc(n);
    pPrev := p;
    p := p^.Next;
  end;
  Result := AllocMem(SizeOf(Result^));
  Result^.FD := n;
  if Assigned(pPrev) then
  begin
    Result^.Next := pPrev^.Next;
    pPrev^.Next := Result;
  end
  else
  begin
    Result^.Next := open_files;
    open_files := Result;
  end;
end;

procedure del_open_file(const fp: C_FILE_ptr);
var
  pPrev: C_FILE_ptr;
begin
  if Assigned(open_files) then
  begin
    if open_files = fp then
      open_files := fp^.Next
    else
    begin
      pPrev := open_files;
      repeat
        if pPrev^.Next = fp then
          Break;
        pPrev := pPrev^.Next;
      until not Assigned(pPrev);
      if Assigned(pPrev) then
        pPrev^.Next := fp^.Next;
    end;
  end;
  System.FreeMem(fp);
end;

function _fgetc(Stream: C_FILE_ptr): Integer; cdecl;
var
  c: Byte;
  BytesRead: Cardinal;
begin
  if Assigned(Stream) then
  begin
    if (Stream^.Handle <> Winapi.Windows.INVALID_HANDLE_VALUE) and
       Winapi.Windows.ReadFile(Stream^.Handle, c, SizeOf(c), BytesRead, nil) and
       (BytesRead = SizeOf(c)) then
    begin
      Stream^.Flags := Stream^.Flags and not _F_EOF;
      Result := c;
      Exit;
    end;
    Stream^.Flags := Stream^.Flags or _F_EOF;
  end;
  Result := EOF;
end;

function _fputc(c: Integer; Stream: C_FILE_ptr): Integer; cdecl;
var
  BytesWritten: Cardinal;
begin
  if Assigned(Stream) then
  begin
    if (Stream^.Handle <> Winapi.Windows.INVALID_HANDLE_VALUE) and
       WriteFile(Stream^.Handle, c, 1, BytesWritten, nil) then
    begin
      Result := c;
      Exit;
    end;
  end;
  Result := EOF;
end;

function _fwrite(ptr: Pointer; size, count: Cardinal; stream: C_FILE_ptr): Cardinal; cdecl;
var
  ResultDWORD: DWORD;
begin
  if size = 0 then
  begin
    Result := count;
  end
  else
  begin
    if Assigned(ptr) and Assigned(stream) then
    begin
      if (stream^.Handle <> Winapi.Windows.INVALID_HANDLE_VALUE) and
         Winapi.Windows.WriteFile(stream^.Handle, ptr^, size * count, ResultDWORD, nil) then
      begin
        Result := ResultDWORD div size;
        Exit;
      end;
    end;
    Result := 0;
  end;
end;

function _fputs(s: PAnsiChar; stream: C_FILE_ptr): Integer; cdecl;
begin
  Result := _fwrite(s, StrLenA(s), 1, stream);
end;

