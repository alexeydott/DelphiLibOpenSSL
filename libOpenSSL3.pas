function SSL_CTX_set_min_proto_version(ctx: SSL_CTX_ptr; version: Integer): Integer;
begin
  Result := SSL_CTX_ctrl(ctx, SSL_CTRL_SET_MIN_PROTO_VERSION, version, nil);
end;

function SSL_CTX_set_max_proto_version(ctx: SSL_CTX_ptr; version: Integer): Integer;
begin
  Result := SSL_CTX_ctrl(ctx, SSL_CTRL_SET_MAX_PROTO_VERSION, version, nil);
end;

function SSL_CTX_get_min_proto_version(ctx: SSL_CTX_ptr): Integer;
begin
  Result := SSL_CTX_ctrl(ctx, SSL_CTRL_GET_MIN_PROTO_VERSION, 0, nil);
end;

function SSL_CTX_get_max_proto_version(ctx: SSL_CTX_ptr): Integer;
begin
  Result := SSL_CTX_ctrl(ctx, SSL_CTRL_GET_MAX_PROTO_VERSION, 0, nil);
end;

