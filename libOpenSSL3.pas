// POSIX file I/O (bcc32 CRT wrappers to Windows API)
function __close(fd: Integer): Integer; cdecl;
begin
  if fd > 2 then
  begin
    if not CloseHandle(THandle(fd)) then
    begin
      errno := EBADF;
      Result := -1;
      Exit;
    end;
  end;
  Result := 0;
end;

function __read(fd: Integer; buf: Pointer; count: Cardinal): Integer; cdecl;
var
  bytesRead: DWORD;
begin
  if ReadFile(THandle(fd), buf^, count, bytesRead, nil) then
    Result := Integer(bytesRead)
  else
    Result := -1;
end;

function __write(fd: Integer; buf: Pointer; count: Cardinal): Integer; cdecl;
var
  bytesWritten: DWORD;
begin
  if WriteFile(THandle(fd), buf^, count, bytesWritten, nil) then
    Result := Integer(bytesWritten)
  else
    Result := -1;
end;

