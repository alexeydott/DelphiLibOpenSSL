// === MSVC compiler intrinsics (64-bit math) ===
// These use custom calling conventions: EDX:EAX for 64-bit args
// JMP bridge from COFF _llumod → Pascal llumod etc.
function llumod(a_lo, a_hi, b_lo, b_hi: Cardinal): UInt64; cdecl;
var a, b: UInt64;
begin
  Int64Rec(a).Lo := a_lo; Int64Rec(a).Hi := a_hi;
  Int64Rec(b).Lo := b_lo; Int64Rec(b).Hi := b_hi;
  if b = 0 then Result := 0
  else Result := a mod b;
end;
function lludiv(a_lo, a_hi, b_lo, b_hi: Cardinal): UInt64; cdecl;
var a, b: UInt64;
begin
  Int64Rec(a).Lo := a_lo; Int64Rec(a).Hi := a_hi;
  Int64Rec(b).Lo := b_lo; Int64Rec(b).Hi := b_hi;
  if b = 0 then Result := 0
  else Result := a div b;
end;
function llmul(a_lo, a_hi, b_lo, b_hi: Cardinal): UInt64; cdecl;
var a, b: UInt64;
begin
  Int64Rec(a).Lo := a_lo; Int64Rec(a).Hi := a_hi;
  Int64Rec(b).Lo := b_lo; Int64Rec(b).Hi := b_hi;
  Result := a * b;
end;
function ftoul(f: Double): Cardinal; cdecl;
begin
  if f < 0 then Result := 0
  else if f > 4294967295.0 then Result := $FFFFFFFF
  else Result := Trunc(f);
end;

