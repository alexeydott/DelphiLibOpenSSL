// --- File I/O (stdio) ---
type
  C_FILE_ptr_msc = ^C_FILE_rec_msc;
  C_FILE_rec_msc = record Handle: THandle; Mode: Integer; IsOpen: Boolean; IsEOF: Boolean; IsError: Boolean; end;
const
  MAX_OPEN_FILES_MSC = 64;
var
  _open_files_msc: array[0..MAX_OPEN_FILES_MSC - 1] of C_FILE_ptr_msc;

function new_open_file_msc: C_FILE_ptr_msc;
var i: Integer;
begin
  for i := 0 to MAX_OPEN_FILES_MSC - 1 do
    if _open_files_msc[i] = nil then begin
      New(Result); Result^.IsOpen := False; Result^.IsEOF := False; Result^.IsError := False;
      _open_files_msc[i] := Result; Exit;
    end;
  Result := nil;
end;

procedure del_open_file_msc(f: C_FILE_ptr_msc);
var i: Integer;
begin
  for i := 0 to MAX_OPEN_FILES_MSC - 1 do
    if _open_files_msc[i] = f then begin _open_files_msc[i] := nil; Dispose(f); Exit; end;
end;

function fopen(filename, mode: PAnsiChar): Pointer; cdecl;
var f: C_FILE_ptr_msc; dwAccess, dwShare, dwCreate: DWORD; h: THandle; mi: Integer;
begin
  Result := nil; f := new_open_file_msc; if f = nil then Exit;
  dwAccess := 0; dwShare := 1; dwCreate := 3;
  if (mode[0] = 'r') then begin dwAccess := $80000000; dwCreate := 3; end
  else if (mode[0] = 'w') then begin dwAccess := $40000000; dwCreate := 2; end
  else if (mode[0] = 'a') then begin dwAccess := $40000000; dwCreate := 4; end;
  mi := 1;
  if (mode[mi] = 'b') or (mode[mi] = 't') then Inc(mi);
  if mode[mi] = '+' then dwAccess := $80000000 or $40000000;
  h := Winapi.Windows.CreateFileA(filename, dwAccess, dwShare, nil, dwCreate, $80, 0);
  if h = INVALID_HANDLE_VALUE then begin del_open_file_msc(f); Exit; end;
  if mode[0] = 'a' then Winapi.Windows.SetFilePointer(h, 0, nil, 2);
  f^.Handle := h; f^.IsOpen := True; f^.Mode := Ord(mode[0]);
  Result := f;
end;

function fclose(stream: Pointer): Integer; cdecl;
var f: C_FILE_ptr_msc;
begin
  f := stream; if (f = nil) or not f^.IsOpen then begin Result := -1; Exit; end;
  Winapi.Windows.CloseHandle(f^.Handle); f^.IsOpen := False; del_open_file_msc(f); Result := 0;
end;

function fread(buf: Pointer; size, count: Cardinal; stream: Pointer): Cardinal; cdecl;
var f: C_FILE_ptr_msc; total, bytesRead: DWORD;
begin
  f := stream; Result := 0; if (f = nil) or not f^.IsOpen then Exit;
  total := size * count;
  if Winapi.Windows.ReadFile(f^.Handle, buf^, total, bytesRead, nil) then
    Result := bytesRead div size
  else f^.IsError := True;
  if bytesRead < total then f^.IsEOF := True;
end;

function fwrite(buf: Pointer; size, count: Cardinal; stream: Pointer): Cardinal; cdecl;
var f: C_FILE_ptr_msc; total, bytesWritten: DWORD;
begin
  f := stream; Result := 0; if (f = nil) or not f^.IsOpen then Exit;
  total := size * count;
  if Winapi.Windows.WriteFile(f^.Handle, buf^, total, bytesWritten, nil) then
    Result := bytesWritten div size
  else f^.IsError := True;
end;

function fseek(stream: Pointer; offset: Integer; origin: Integer): Integer; cdecl;
var f: C_FILE_ptr_msc;
begin
  f := stream; if (f = nil) or not f^.IsOpen then begin Result := -1; Exit; end;
  if Winapi.Windows.SetFilePointer(f^.Handle, offset, nil, DWORD(origin)) = DWORD($FFFFFFFF) then Result := -1 else begin Result := 0; f^.IsEOF := False; end;
end;

function ftell(stream: Pointer): Integer; cdecl;
var f: C_FILE_ptr_msc;
begin f := stream; if (f = nil) or not f^.IsOpen then begin Result := -1; Exit; end; Result := Integer(Winapi.Windows.SetFilePointer(f^.Handle, 0, nil, 1)); end;

function feof(stream: Pointer): Integer; cdecl;
var f: C_FILE_ptr_msc;
begin f := stream; if f = nil then Result := 1 else if f^.IsEOF then Result := 1 else Result := 0; end;

function ferror(stream: Pointer): Integer; cdecl;
var f: C_FILE_ptr_msc;
begin f := stream; if f = nil then Result := 1 else if f^.IsError then Result := 1 else Result := 0; end;

procedure clearerr(stream: Pointer); cdecl;
var f: C_FILE_ptr_msc;
begin f := stream; if f <> nil then begin f^.IsEOF := False; f^.IsError := False; end; end;

function fflush(stream: Pointer): Integer; cdecl;
var f: C_FILE_ptr_msc;
begin f := stream; if (f = nil) or not f^.IsOpen then begin Result := 0; Exit; end; if Winapi.Windows.FlushFileBuffers(f^.Handle) then Result := 0 else Result := -1; end;

function fputc(c: Integer; stream: Pointer): Integer; cdecl;
var f: C_FILE_ptr_msc; b: Byte; bw: DWORD;
begin f := stream; b := Byte(c); if Winapi.Windows.WriteFile(f^.Handle, b, 1, bw, nil) then Result := c else begin f^.IsError := True; Result := -1; end; end;

function fgetc(stream: Pointer): Integer; cdecl;
var f: C_FILE_ptr_msc; b: Byte; br: DWORD;
begin
  f := stream; if not Winapi.Windows.ReadFile(f^.Handle, b, 1, br, nil) or (br = 0) then begin f^.IsEOF := True; Result := -1; end else Result := b;
end;

function fputs(s: PAnsiChar; stream: Pointer): Integer; cdecl;
var f: C_FILE_ptr_msc; len, bw: DWORD;
begin f := stream; len := StrLenA(s); if Winapi.Windows.WriteFile(f^.Handle, s^, len, bw, nil) then Result := Integer(bw) else begin f^.IsError := True; Result := -1; end; end;

function fgets(buf: PAnsiChar; count: Integer; stream: Pointer): PAnsiChar; cdecl;
var f: C_FILE_ptr_msc; i: Integer; b: Byte; br: DWORD;
begin
  f := stream; Result := nil; if (f = nil) or (count <= 0) then Exit;
  for i := 0 to count - 2 do begin
    if not Winapi.Windows.ReadFile(f^.Handle, b, 1, br, nil) or (br = 0) then begin f^.IsEOF := True; if i = 0 then Exit; buf[i] := #0; Result := buf; Exit; end;
    buf[i] := AnsiChar(b);
    if b = 10 then begin buf[i + 1] := #0; Result := buf; Exit; end;
  end;
  buf[count - 1] := #0; Result := buf;
end;

