  div     ebx
  xor     edx, edx
@__lldiv@finish:
  test    esi, esi
  jns     @__lldiv@done
  neg     edx
  neg     eax
  sbb     edx, 0
@__lldiv@done:
  pop     edi
  pop     esi
  pop     ebx
  pop     ebp
  ret     8
end;

