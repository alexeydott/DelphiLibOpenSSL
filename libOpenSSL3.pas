function _time(t: Pointer): Integer; cdecl;
var
  ft: Int64;
begin
  GetSystemTimeAsFileTime(PFileTime(@ft)^);
  Result := Integer((ft - 116444736000000000) div 10000000);
  if t <> nil then PInteger(t)^ := Result;
end;

