// === MSVC Win32: CRT cdecl implementations ===
// COFF objects reference '_memcpy' etc. msc32_coff_bridges.obj provides JMP thunks
// from decorated COFF names to these plain Delphi OMF PUBDEFs.

// --- Core memory / string ---
function memset(dest: Pointer; c: Integer; n: Cardinal): Pointer; cdecl;
begin FillChar(dest^, n, Byte(c)); Result := dest; end;

function memcpy(dest, src: Pointer; n: Cardinal): Pointer; cdecl;
begin Move(src^, dest^, n); Result := dest; end;

function memmove(dest, src: Pointer; n: Cardinal): Pointer; cdecl;
begin Move(src^, dest^, n); Result := dest; end;

function memchr(s: Pointer; c: Integer; n: Cardinal): Pointer; cdecl;
var p: PByte; i: Cardinal;
begin
  p := s;
  for i := 0 to n - 1 do begin if p^ = Byte(c) then begin Result := p; Exit; end; Inc(p); end;
  Result := nil;
end;

function memcmp(s1, s2: Pointer; n: Cardinal): Integer; cdecl;
var p1, p2: PByte; i: Cardinal;
begin
  p1 := s1; p2 := s2;
  for i := 0 to n - 1 do begin
    if p1^ <> p2^ then begin if p1^ < p2^ then Result := -1 else Result := 1; Exit; end;
    Inc(p1); Inc(p2);
  end;
  Result := 0;
end;

function strlen(s: PAnsiChar): Cardinal; cdecl;
begin Result := StrLenA(s) end;

function strcmp(s1, s2: PAnsiChar): Integer; cdecl;
begin
  while (s1^ = s2^) and (s1^ <> #0) do begin Inc(s1); Inc(s2); end;
  Result := Ord(s1^) - Ord(s2^);
end;

function strncmp(s1, s2: PAnsiChar; n: Cardinal): Integer; cdecl;
var i: Cardinal;
begin
  for i := 0 to n - 1 do begin
    if s1[i] <> s2[i] then begin if Byte(s1[i]) < Byte(s2[i]) then Result := -1 else Result := 1; Exit; end;
    if s1[i] = #0 then begin Result := 0; Exit; end;
  end;
  Result := 0;
end;

function strncpy(dest, src: PAnsiChar; n: Cardinal): PAnsiChar; cdecl;
var i, j: Cardinal;
begin
  Result := dest;
  for i := 0 to n - 1 do begin
    if src[i] = #0 then begin j := i; while j < n do begin dest[j] := #0; Inc(j); end; Exit; end;
    dest[i] := src[i];
  end;
end;

function strcpy(dest, src: PAnsiChar): PAnsiChar; cdecl;
begin Result := dest; while src^ <> #0 do begin dest^ := src^; Inc(dest); Inc(src); end; dest^ := #0; end;

function strcat(dest, src: PAnsiChar): PAnsiChar; cdecl;
var p: PAnsiChar;
begin Result := dest; p := dest; while p^ <> #0 do Inc(p); while src^ <> #0 do begin p^ := src^; Inc(p); Inc(src); end; p^ := #0; end;

function strchr(s: PAnsiChar; c: Integer): PAnsiChar; cdecl;
begin
  while s^ <> #0 do begin if Byte(s^) = Byte(c) then begin Result := s; Exit; end; Inc(s); end;
  if Byte(c) = 0 then Result := s else Result := nil;
end;

function strrchr(s: PAnsiChar; c: Integer): PAnsiChar; cdecl;
var p: PAnsiChar;
begin
  Result := nil; p := s;
  while p^ <> #0 do begin if Byte(p^) = Byte(c) then Result := p; Inc(p); end;
  if Byte(c) = 0 then Result := p;
end;

function strstr(s1, s2: PAnsiChar): PAnsiChar; cdecl;
var len2: Cardinal; p: PAnsiChar;
begin
  if s2^ = #0 then begin Result := s1; Exit; end;
  len2 := strlen(s2);
  p := s1;
  while p^ <> #0 do begin
    if CompareMem(p, s2, len2) then begin Result := p; Exit; end;
    Inc(p);
  end;
  Result := nil;
end;

function strpbrk(s1, s2: PAnsiChar): PAnsiChar; cdecl;
var p, q: PAnsiChar;
begin
  p := s1;
  while p^ <> #0 do begin
    q := s2; while q^ <> #0 do begin if p^ = q^ then begin Result := p; Exit; end; Inc(q); end;
    Inc(p);
  end;
  Result := nil;
end;

function strspn(s1, s2: PAnsiChar): Cardinal; cdecl;
var p, q: PAnsiChar; found: Boolean;
begin
  Result := 0; p := s1;
  while p^ <> #0 do begin
    found := False; q := s2;
    while q^ <> #0 do begin if p^ = q^ then begin found := True; Break; end; Inc(q); end;
    if not found then Exit;
    Inc(Result); Inc(p);
  end;
end;

function strcspn(s1, s2: PAnsiChar): Cardinal; cdecl;
var p, q: PAnsiChar;
begin
  Result := 0; p := s1;
  while p^ <> #0 do begin
    q := s2; while q^ <> #0 do begin if p^ = q^ then Exit; Inc(q); end;
    Inc(Result); Inc(p);
  end;
end;

function strtol(s: PAnsiChar; endptr: Pointer; base: Integer): Integer; cdecl;
var Code: Integer; v: Int64; p: PAnsiChar;
begin
  p := s; while (p^ = ' ') or (p^ = #9) do Inc(p);
  Val(string(p), v, Code);
  if Assigned(endptr) then begin if Code = 0 then PPAnsiChar(endptr)^ := s + strlen(s) else PPAnsiChar(endptr)^ := s + (p - s) + Code - 1; end;
  Result := Integer(v);
end;

function strtoul(s: PAnsiChar; endptr: Pointer; base: Integer): Cardinal; cdecl;
var Code: Integer; v: Int64; p: PAnsiChar;
begin
  p := s; while (p^ = ' ') or (p^ = #9) do Inc(p);
  Val(string(p), v, Code);
  if Assigned(endptr) then begin if Code = 0 then PPAnsiChar(endptr)^ := s + strlen(s) else PPAnsiChar(endptr)^ := s + (p - s) + Code - 1; end;
  Result := Cardinal(v);
end;

