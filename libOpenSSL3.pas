// --- Sort / signal ---
type TQSortCompare_msc = function(a, b: Pointer): Integer; cdecl;

procedure qsort(base: Pointer; num, size: Cardinal; compare: TQSortCompare_msc); cdecl;
var i, j: Cardinal; temp: Pointer; pi, pj: PByte;
begin
  if (num < 2) or (size = 0) then Exit;
  GetMem(temp, size);
  try
    for i := 0 to num - 2 do
      for j := 0 to num - i - 2 do begin
        pi := PByte(base) + j * size; pj := pi + size;
        if compare(pi, pj) > 0 then begin Move(pi^, temp^, size); Move(pj^, pi^, size); Move(temp^, pj^, size); end;
      end;
  finally FreeMem(temp); end;
end;

