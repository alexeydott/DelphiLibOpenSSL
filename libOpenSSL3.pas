// stdio stubs
function _fclose(stream: C_FILE_ptr): Integer; cdecl;
begin
  if Assigned(stream) then
  begin
    if (stream^.Handle <> Winapi.Windows.INVALID_HANDLE_VALUE) and
       Winapi.Windows.CloseHandle(stream^.Handle) then
    begin
      if stream^.static_ then
        stream^.Handle := Winapi.Windows.INVALID_HANDLE_VALUE
      else
        del_open_file(stream);
      Result := 0;
      Exit;
    end;
    stream^.Flags := stream^.Flags and not _F_EOF;
  end;
  Result := EOF;
end;

function _fread(Ptr: Pointer; Size: NativeUint; n: NativeUint; Stream: C_FILE_ptr): NativeUint; cdecl;
label
  Error;
var

  ResultDWORD: DWORD;
  Total: NativeUint;
begin
  if Size = 0 then
  begin
    Result := n
  end
  else
  begin
    if Assigned(Ptr) and Assigned(Stream) then
    begin
      Total := Size * n;

      if not Winapi.Windows.ReadFile(Stream^.Handle, Ptr^, Total, ResultDWORD, nil) then
        goto Error;
      Result := ResultDWORD;

      if Result < Total then
        Stream^.Flags := Stream^.Flags or _F_EOF;
      Result := Result div Size;
      Exit;
    end;
  Error:
    Result := 0;
  end;
end;


function _ferror(stream: C_FILE_ptr): Integer; cdecl;
begin
  Result := 0;
end;

function _fseek(stream: C_FILE_ptr; offset: Integer; whence: Integer): Integer; cdecl;
const
  INVALID_SET_FILE_POINTER = DWORD(-1);
var
  dwMoveMethod: DWORD;
begin
  if not Assigned(stream) then
  begin
    errno := EBADF;
    Result := 1;
    Exit;
  end;
  stream^.Flags := stream^.Flags and not _F_EOF;
  if stream^.Handle = Winapi.Windows.INVALID_HANDLE_VALUE then
  begin
    errno := EBADF;
    Result := 1;
    Exit;
  end;
  case whence of
    SEEK_SET: dwMoveMethod := Winapi.Windows.FILE_BEGIN;
    SEEK_CUR: dwMoveMethod := Winapi.Windows.FILE_CURRENT;
    SEEK_END: dwMoveMethod := Winapi.Windows.FILE_END;
  else
    errno := EINVAL;
    Result := 1;
    Exit;
  end;
  if Winapi.Windows.SetFilePointer(stream^.Handle, offset, nil, dwMoveMethod) = INVALID_SET_FILE_POINTER then
  begin
    errno := ESPIPE;
    Result := 1;
    Exit;
  end;
  Result := 0;
end;

function _feof(stream: C_FILE_ptr): Integer; cdecl;
begin
  if Assigned(stream) then
    Result := stream^.Flags and _F_EOF
  else
    Result := 0;
end;

function _ftell(stream: C_FILE_ptr): Integer; cdecl;
begin
  if Assigned(stream) then
    Result := Integer(Winapi.Windows.SetFilePointer(stream^.Handle, 0, nil, Winapi.Windows.FILE_CURRENT))
  else
    Result := -1;
end;

function _fflush(stream: C_FILE_ptr): Integer; cdecl;
begin
  if Assigned(stream) then
  begin
    if (stream^.Handle <> Winapi.Windows.INVALID_HANDLE_VALUE) and
       (FlushFileBuffers(stream^.Handle) or (GetLastError = ERROR_INVALID_HANDLE)) then
      Result := 0
    else
      Result := EOF;
  end
  else
    Result := EOF;
end;

function _fgets(buf: PAnsiChar; n: Integer; stream: C_FILE_ptr): PAnsiChar; cdecl;
var
  c: Integer;
  p: PAnsiChar;
begin
  p := buf;
  c := 0;
  Dec(n);
  while n > 0 do
  begin
    c := _fgetc(stream);
    if c = EOF then
      Break;
    p^ := AnsiChar(c);
    Inc(p);
    if c = $A then
      Break;
    Dec(n);
  end;
  if (c = EOF) and (p = buf) then
    Result := nil
  else
  begin
    p^ := #0;
    Result := buf;
  end;
end;

type
  TStat = packed record
    st_dev: Cardinal;
    st_ino: Word;
    st_mode: Word;
    st_nlink: Word;
    st_uid: Word;
    st_gid: Word;
    st_rdev: Cardinal;
    st_size: Integer;
    st_atime: Integer;
    st_mtime: Integer;
    st_ctime: Integer;
  end;

function __stat(path: PAnsiChar; buf: Pointer): Integer; cdecl;
var
  hFind: THandle;
  fd: TWin32FindDataA;
  pStat: ^TStat;
begin
  if (path = nil) or (buf = nil) then begin Result := -1; Exit; end;
  hFind := FindFirstFileA(path, fd);
  if hFind = INVALID_HANDLE_VALUE then begin Result := -1; Exit; end;
  Winapi.Windows.FindClose(hFind);
  pStat := buf;
  FillChar(pStat^, SizeOf(TStat), 0);
  pStat^.st_size := fd.nFileSizeLow;
  if (fd.dwFileAttributes and FILE_ATTRIBUTE_DIRECTORY) <> 0 then
    pStat^.st_mode := $4000 or $01FF
  else
    pStat^.st_mode := $8000 or $01FF;
  Result := 0;
end;

