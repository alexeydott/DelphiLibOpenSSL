// Inline OPENSSL memory wrappers

function EVP_MD_CTX_get_size(const ctx: EVP_MD_CTX_ptr): Integer;
begin
  Result := EVP_MD_get_size(EVP_MD_CTX_get0_md(ctx));
end;

function SSL_CTX_set_session_cache_mode(ctx: SSL_CTX_ptr; mode: Integer): Integer;
const
  SSL_CTRL_SET_SESS_CACHE_MODE = 44;
begin
  Result := SSL_CTX_ctrl(ctx, SSL_CTRL_SET_SESS_CACHE_MODE, mode, nil);
end;

function SSL_CTX_get_session_cache_mode(ctx: SSL_CTX_ptr): Integer;
const
  SSL_CTRL_GET_SESS_CACHE_MODE = 45;
begin
  Result := SSL_CTX_ctrl(ctx, SSL_CTRL_GET_SESS_CACHE_MODE, 0, nil);
end;

function OPENSSL_malloc(const Num: NativeUInt): Pointer;
begin
  Result := CRYPTO_malloc(Num, nil, 0);
end;

function OPENSSL_zalloc(const Num: NativeUInt): Pointer;
begin
  Result := CRYPTO_zalloc(Num, nil, 0);
end;

procedure OPENSSL_free(const Addr: Pointer);
begin
  CRYPTO_free(Addr, nil, 0);
end;

function OPENSSL_strdup(const Str: PAnsiChar): PAnsiChar;
begin
  Result := CRYPTO_strdup(Str, nil, 0);
end;

function OPENSSL_memdup(const Data: Pointer; Num: NativeUInt): Pointer;
begin
  Result := CRYPTO_memdup(Data, Num, nil, 0);
end;

procedure OPENSSL_clear_free(Addr: Pointer; Num: NativeUInt);
begin
  CRYPTO_clear_free(Addr, Num, nil, 0);
end;

