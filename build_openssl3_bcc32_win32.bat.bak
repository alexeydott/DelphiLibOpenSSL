@echo off

setlocal EnableDelayedExpansion

REM ============================================================================
REM  Build OpenSSL 4.x for Win32 using Embarcadero bcc32 (classic)
REM
REM  Uses bcc32 with -pr (register calling convention) to produce OMF objects
REM  with clean symbol names matching Delphi default calling convention.
REM  Object file naming matches MSVC build convention for {$L} compatibility.
REM
REM  Output:
REM    .\obj3\win32\bcc\*_win32.obj  -  OMF object files for static linking with dcc32
REM ============================================================================

set "RSVARS=D:\Embarcadero RAD Studio\23.0\bin\rsvars.bat"

REM === Setup RAD Studio environment ===
if not exist "%RSVARS%" (
    echo ERROR: RAD Studio rsvars.bat not found at:
    echo   %RSVARS%
    echo.
    echo Edit RSVARS in this script to match your RAD Studio installation path.
    exit /b 1
)
call "%RSVARS%"

REM Guarantee compiler/tools come from the same RAD Studio version as RSVARS.
REM Multiple RAD Studio versions may be on PATH; prepend the RSVARS bin directory
REM so bcc32, make, tlib etc. always resolve to the intended version.
for %%I in ("%RSVARS%") do set "PATH=%%~dpI;%PATH%"

REM === Check prerequisites ===
where bcc32.exe >nul 2>&1
if errorlevel 1 (
    echo ERROR: bcc32.exe not found. RAD Studio environment not set up correctly.
    exit /b 1
)

cd /d "D:\projects\externals\libopenssl\c_src\openssl"

REM === Patch sources for static linking (all compilers) ===
echo Patching OpenSSL sources for static linking...
where python >nul 2>&1
if errorlevel 1 (
    echo ERROR: Python not found in PATH. Required for patching.
    exit /b 1
)
python "%~dp0helpers\patch_static_link.py" --apply
if errorlevel 1 (
    echo WARNING: Static-link patching reported errors.
)

REM === Patch sources for C89 compatibility (BCC32 classic) ===
echo Patching OpenSSL sources for BCC32 C89 compatibility...
python "%~dp0helpers\patch_c89.py" --apply
if errorlevel 1 (
    echo WARNING: C89 patching reported errors. Build may fail.
)
echo.

set CC=bcc32
set BCCFLAGS=-c -pr -O2 -q -X -w-8057 -w-8004 -w-8008 -w-8066 -w-8019
set DEFINES=-DSTATIC_LEGACY -DOPENSSL_STATIC_LINK -DWIN32_LEAN_AND_MEAN -DOPENSSL_SYS_WIN32 -DL_ENDIAN -DDSO_WIN32 -DNDEBUG -DOPENSSL_NO_LOCALE -D_locale_t=void* -D_WIN32_WINNT=0x0601 -D_WSPIAPI_H_ -DOPENSSL_NO_DYNAMIC_ENGINE -DOPENSSL_NO_AFALGENG -DOPENSSL_SMALL_FOOTPRINT -DOPENSSL_NO_ENGINE -DOPENSSL_NO_ASM -DOPENSSL_PIC -D_MSTCPIP_ -DDECLSPEC_IMPORT=
REM Fix Delphi case-insensitive linker collisions (see helpers\openssl_fix_case_collisions.h)
REM BCC32 classic does not support -include, so we pass the renames as -D flags.
set DEFINES=%DEFINES% -Dossl_provider_query_operation=ossl_provider_query_operation_ -Dossl_provider_get_capabilities=ossl_provider_get_capabilities_ -Dossl_provider_get_params=ossl_provider_get_params_ -Dossl_provider_get0_dispatch=ossl_provider_get0_dispatch_ -Dossl_provider_gettable_params=ossl_provider_gettable_params_ -Dossl_provider_self_test=ossl_provider_self_test_ -Dossl_provider_unquery_operation=ossl_provider_unquery_operation_
set DEFINES=%DEFINES% -Dossl_lib_ctx_get_data=ossl_lib_ctx_get_data_ -Dossl_hpke_str2suite=ossl_hpke_str2suite_ -Dossl_cmp_pollRep_new=ossl_cmp_pollRep_new_ -Dossl_cmp_pollReq_new=ossl_cmp_pollReq_new_ -DOCSP_crlID_new=OCSP_crlID_new_ -Dd2i_ECPKParameters=d2i_ECPKParameters_ -Di2d_ECPKParameters=i2d_ECPKParameters_ -Dpoly1305_init=poly1305_init_ -Dssl_session_dup=ssl_session_dup_ -DEVP_Cipher=EVP_Cipher_
set OBJDIR=D:\projects\externals\libopenssl\obj3\win32\bcc

if not exist "%OBJDIR%" mkdir "%OBJDIR%"


set /a TOTAL=1104

set /a COUNT=0

set /a ERRORS=0



echo Building %TOTAL% files with bcc32 (register convention)...

echo.



%CC% %BCCFLAGS% %DEFINES% -I"." -I"include" -I"providers\common\include" -I"providers\implementations\include" -I"providers\fips\include" -DOPENSSLDIR=\".\" -DMODULESDIR=\".\" -o"%OBJDIR%\libcrypto-lib-aes_cbc_win32.obj" "crypto\aes\aes_cbc.c"

if errorlevel 1 (set /a ERRORS+=1) else (set /a COUNT+=1)

%CC% %BCCFLAGS% %DEFINES% -I"." -I"include" -I"providers\common\include" -I"providers\implementations\include" -I"providers\fips\include" -DOPENSSLDIR=\".\" -DMODULESDIR=\".\" -o"%OBJDIR%\libcrypto-lib-aes_cfb_win32.obj" "crypto\aes\aes_cfb.c"

if errorlevel 1 (set /a ERRORS+=1) else (set /a COUNT+=1)

